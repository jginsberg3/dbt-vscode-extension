{
  "name": "dbt-navigator",
  "displayName": "dbt Navigator",
  "description": "Go-to-definition, DAG visualization, and multi-project support for dbt",
  "version": "0.1.0",
  "publisher": "dbt-navigator",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:sql",
    "onLanguage:jinja-sql",
    "onLanguage:yaml",
    "workspaceContains:**/dbt_project.yml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dbt.switchProject",
        "title": "dbt: Switch Project"
      },
      {
        "command": "dbt.compile",
        "title": "dbt: Compile Project"
      }
    ],
    "configuration": {
      "title": "dbt Navigator",
      "properties": {
        "dbtNavigator.dbtCommand": {
          "type": "string",
          "default": "auto",
          "description": "The command used to run dbt. Set to 'auto' (default) to search for dbt in .venv/bin, venv/bin, then fall back to PATH. Set to a custom value like '/path/to/dbt' or 'python -m dbt' to override."
        }
      }
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "dbt-dag-panel",
          "title": "dbt DAG",
          "icon": "$(type-hierarchy)"
        }
      ]
    },
    "views": {
      "dbt-dag-panel": [
        {
          "type": "webview",
          "id": "dbtNavigator.dagView",
          "name": "dbt DAG",
          "icon": "$(type-hierarchy)"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "elkjs": "^0.9.0"
  }
}
