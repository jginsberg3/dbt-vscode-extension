{
  "name": "dbt-navigator",
  "displayName": "dbt Navigator",
  "description": "Go-to-definition, DAG visualization, and multi-project support for dbt",
  "version": "0.1.0",
  "publisher": "dbt-navigator",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:sql",
    "onLanguage:jinja-sql",
    "workspaceContains:**/dbt_project.yml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dbt.showDag",
        "title": "dbt: Show DAG"
      },
      {
        "command": "dbt.switchProject",
        "title": "dbt: Switch Project"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "elkjs": "^0.9.0"
  }
}
